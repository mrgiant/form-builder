{
    "name": "mrgiant/form-builder",
    "description": "A Laravel form-builder module: dynamic forms, questions, responses, approval workflows, with Vue 3 builder components and Blade renderers.",
    "type": "library",
    "version": "0.1.3",
    "license": "MIT",
    "keywords": [
        "laravel",
        "forms",
        "form-builder",
        "vue",
        "workflow",
        "approvals"
    ],
    "authors": [
        {
            "name": "Mohamed Al Wahaibi",
            "email": "mohamed.alwahaibi@golden-logic.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/mrgiant/form-builder",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0",
        "maatwebsite/excel": "^3.1"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Mrgiant\\FormBuilder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mrgiant\\FormBuilder\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mrgiant\\FormBuilder\\FormBuilderServiceProvider"
            ]
        }
    }
}
